# Copy this file to .env.local and fill in the values.
# Used by Next.js at runtime.

# Turso database (get from: turso db show <db-name> + turso db tokens create <db-name>)
DATABASE_URL="libsql://[db-name]-[org].turso.io"
TURSO_AUTH_TOKEN=""

# NextAuth — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""

# Your production URL (set automatically by Vercel if left blank)
# AUTH_URL="https://your-app.vercel.app"
